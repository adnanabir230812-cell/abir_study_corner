<%- include('partials/header') %>

<!-- Back Link -->
<div class="mb-6">
  <a href="/courses/<%= course.id %>" class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors">
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    Back to Course Overview
  </a>
</div>

<!-- Header -->
<div class="mb-8">
  <span class="text-xs font-bold text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-slate-800 px-3 py-1 rounded-full uppercase tracking-wider">Study Vault</span>
  <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mt-3 tracking-tight">Course Content</h1>
  <p class="text-slate-500 dark:text-slate-400 mt-1"><%= course.name %> (<%= course.code %>) &bull; <%= section.name %> (<%= section.teacherName %>)</p>
</div>

<!-- Notes Board -->
<div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-6 md:p-10 shadow-sm">
  <!-- Original source label -->
  <div class="inline-flex items-center gap-1.5 text-xs font-bold text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950/30 px-2.5 py-1 rounded-md mb-6 border border-emerald-100/30">
    <span>📖</span>
    <span>Source: Original Course Content</span>
  </div>

  <% if (note) { %>
    <!-- Parse and render note -->
    <div class="markdown-content text-slate-700 dark:text-slate-200 text-base leading-relaxed">
      <%- note.parsedContent %>
    </div>
  <% } else { %>
    <div class="text-center py-12 text-slate-400 dark:text-slate-500">
      <div class="text-4xl mb-4">📓</div>
      <h3 class="text-base font-bold text-slate-800 dark:text-white mb-1">No notes uploaded for this section</h3>
      <p class="text-sm">Please import notes during Phase 2.</p>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>

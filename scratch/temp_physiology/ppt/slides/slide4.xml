pcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>Pathogens damage leaf tissues </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>– reduced photosynthetic area examples of such diseases</a:t></a:r></a:p><a:p><a:pPr lvl="1" fontAlgn="auto"><a:spcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>Some diseases </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>destroy chloroplasts </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>and cause their </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"/><a:t>disintegration</a:t></a:r></a:p><a:p><a:pPr lvl="1" fontAlgn="auto"><a:spcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>Pathogens </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>produce toxins </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>such as </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0" err="1"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>tentoxin</a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t> and </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0" err="1"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>tabtoxin</a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t> </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>which </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>inhibit enzymes </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>involved in photosynthesis</a:t></a:r></a:p><a:p><a:pPr lvl="1" fontAlgn="auto"><a:spcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>Vascular pathogens </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>reduce chlorophyll content </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>and photosynthesis stops before wilting</a:t></a:r></a:p><a:p><a:pPr lvl="1" fontAlgn="auto"><a:spcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>Viruses and </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0" err="1"/><a:t>mollicute</a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t> </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>cause </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0" err="1"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>chlorosis</a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t> </a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t>and </a:t></a:r><a:r><a:rPr lang="en-ZW" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>stunting</a:t></a:r><a:r><a:rPr lang="en-ZW" dirty="0"/><a:t> – photosynthesis is greatly reduced</a:t></a:r></a:p><a:p><a:pPr lvl="1" fontAlgn="auto"><a:spcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:endParaRPr lang="en-ZW" dirty="0"/></a:p><a:p><a:pPr lvl="1" fontAlgn="auto"><a:spcAft><a:spcPts val="0"/></a:spcAft><a:buFont typeface="Arial" pitchFamily="34" charset="0"/><a:buChar char="–"/><a:defRPr/></a:pPr><a:endParaRPr lang="sq-AL" dirty="0"/></a:p></p:txBody